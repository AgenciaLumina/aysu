# Banco
DATABASE_URL=
DIRECT_URL=

# Segurança operacional local
# Use 1 quando o ambiente local estiver conectado ao banco de produção.
APP_READ_ONLY_MODE=1

# Hold de pendência de reserva (em minutos)
# 0 = comportamento legado (pendente sempre trava estoque)
PENDING_HOLD_MINUTES=0

# Site
# Em produção isso costuma ficar false.
MAINTENANCE_MODE=false
